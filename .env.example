# 复制本文件为 .env,填入真实值(.env 不入 git)。
# 模型 / 链接 / 密钥都存这里;config.json 只用 ${变量名} 引用,要换就改下面这几行。

# remote 模式 —— 远端 SaaS 的模型 / 地址 / 密钥(默认 DeepSeek,想换 ByteDance 等改对应行即可)
REMOTE_MODEL=deepseek-v4-flash
REMOTE_BASE_URL=https://api.deepseek.com
# 当前是 DeepSeek 的 API Key;换别家远端时连同 REMOTE_BASE_URL 一起改
REMOTE_API_KEY=xxxxxxxx

# local 模式 —— 本地服务的模型 / 地址(LM Studio 等,无需密钥)
LOCAL_MODEL=qwen3-30b-a3b
LOCAL_BASE_URL=http://localhost:1234/v1
