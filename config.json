{
  "llm": {
    "model": "deepseek-v4-flash",
    "base_url": "https://api.deepseek.com",
    "api_key_env": "DEEPSEEK_API_KEY"
  },
  "memory": {
    "compression": {
      "trigger_size": 150,
      "keep_recent": 80
    }
  },
  "simulation": {
    "num_turns": 5
  },
  "persistence": {
    "enabled": true,
    "data_dir": "data"
  }
}
