{
  "llm": {
    "active": "remote",
    "profiles": {
      "remote": {
        "model": "${REMOTE_MODEL}",
        "base_url": "${REMOTE_BASE_URL}",
        "api_key_env": "REMOTE_API_KEY"
      },
      "local": {
        "model": "${LOCAL_MODEL}",
        "base_url": "${LOCAL_BASE_URL}",
        "params": {
          "temperature": 0.7,
          "top_p": 0.8,
          "top_k": 20,
          "min_p": 0,
          "presence_penalty": 1.0,
          "max_tokens": 2048
        }
      }
    }
  },
  "memory": {
    "compression": {
      "trigger_size": 60,
      "keep_recent": 20
    },
    "reflection": {
      "interval": 12,
      "max_beliefs": 8
    }
  },
  "simulation": {
    "num_turns": 5
  },
  "persistence": {
    "enabled": true,
    "data_dir": "data"
  }
}
